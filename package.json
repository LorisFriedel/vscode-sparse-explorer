{
  "name": "vscode-sparse-explorer",
  "displayName": "VSCode Sparse Explorer",
  "description": "A sparse explorer showing only open tabs and pinned files, with expand-all and recursive filter per directory",
  "version": "0.0.3",
  "publisher": "eric-mountain",
  "repository": {
    "type": "git",
    "url": "https://github.com/EricMountain/vscode-sparse-explorer"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "icon": "resources/sparse-explorer-icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sparseExplorer",
          "title": "Sparse Explorer",
          "icon": "resources/sparse-explorer.svg"
        }
      ]
    },
    "views": {
      "sparseExplorer": [
        {
          "id": "sparseExplorer.view",
          "name": "Sparse Explorer"
        }
      ]
    },
    "commands": [
      {
        "command": "sparseExplorer.ejectItem",
        "title": "Remove from View",
        "icon": "$(close)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.expandAll",
        "title": "Show All Files",
        "icon": "$(expand-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.collapseToFiltered",
        "title": "Collapse to Filtered View",
        "icon": "$(collapse-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.filterExpanded",
        "title": "Filter Files...",
        "icon": "$(search)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.clearFilter",
        "title": "Clear Filter",
        "icon": "$(clear-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.revealInExplorer",
        "title": "Reveal in Explorer",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.expandDir",
        "title": "Show All Files",
        "icon": "$(expand-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.collapseDir",
        "title": "Collapse to Filtered View",
        "icon": "$(collapse-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.filterDir",
        "title": "Filter Files...",
        "icon": "$(search)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.clearFilterDir",
        "title": "Clear Filter",
        "icon": "$(clear-all)",
        "category": "Sparse Explorer"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sparseExplorer.filterExpanded",
          "when": "view == sparseExplorer.view && sparseExplorer.hasExpanded && !sparseExplorer.rootHasFilter",
          "group": "navigation@1"
        },
        {
          "command": "sparseExplorer.clearFilter",
          "when": "view == sparseExplorer.view && sparseExplorer.rootHasFilter",
          "group": "navigation@1"
        },
        {
          "command": "sparseExplorer.expandAll",
          "when": "view == sparseExplorer.view && !sparseExplorer.hasExpanded",
          "group": "navigation@2"
        },
        {
          "command": "sparseExplorer.collapseToFiltered",
          "when": "view == sparseExplorer.view && sparseExplorer.hasExpanded",
          "group": "navigation@2"
        },
        {
          "command": "sparseExplorer.refresh",
          "when": "view == sparseExplorer.view",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "sparseExplorer.ejectItem",
          "when": "view == sparseExplorer.view && viewItem == 'seFile'",
          "group": "inline@1"
        },
        {
          "command": "sparseExplorer.expandDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.filtered' || viewItem == 'seDir.workspaceRoot')",
          "group": "inline@1"
        },
        {
          "command": "sparseExplorer.filterDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.expanded' || viewItem == 'seDir.workspaceRoot.expanded')",
          "group": "inline@2"
        },
        {
          "command": "sparseExplorer.clearFilterDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.expandedFiltered' || viewItem == 'seDir.workspaceRoot.expandedFiltered')",
          "group": "inline@2"
        },
        {
          "command": "sparseExplorer.collapseDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.expanded' || viewItem == 'seDir.expandedFiltered' || viewItem == 'seDir.workspaceRoot.expanded' || viewItem == 'seDir.workspaceRoot.expandedFiltered')",
          "group": "inline@3"
        },
        {
          "command": "sparseExplorer.ejectItem",
          "when": "view == sparseExplorer.view && viewItem == 'seFile'",
          "group": "1_actions@1"
        },
        {
          "command": "sparseExplorer.expandDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.filtered' || viewItem == 'seDir.workspaceRoot')",
          "group": "1_actions@1"
        },
        {
          "command": "sparseExplorer.filterDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.expanded' || viewItem == 'seDir.expandedFiltered' || viewItem == 'seDir.workspaceRoot.expanded' || viewItem == 'seDir.workspaceRoot.expandedFiltered')",
          "group": "1_actions@1"
        },
        {
          "command": "sparseExplorer.clearFilterDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.expandedFiltered' || viewItem == 'seDir.workspaceRoot.expandedFiltered')",
          "group": "1_actions@2"
        },
        {
          "command": "sparseExplorer.collapseDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.expanded' || viewItem == 'seDir.expandedFiltered' || viewItem == 'seDir.workspaceRoot.expanded' || viewItem == 'seDir.workspaceRoot.expandedFiltered')",
          "group": "1_actions@3"
        },
        {
          "command": "sparseExplorer.revealInExplorer",
          "when": "view == sparseExplorer.view",
          "group": "2_reveal@1"
        }
      ],
      "commandPalette": [
        {
          "command": "sparseExplorer.ejectItem",
          "when": "false"
        },
        {
          "command": "sparseExplorer.expandAll",
          "when": "false"
        },
        {
          "command": "sparseExplorer.collapseToFiltered",
          "when": "false"
        },
        {
          "command": "sparseExplorer.filterExpanded",
          "when": "false"
        },
        {
          "command": "sparseExplorer.clearFilter",
          "when": "false"
        },
        {
          "command": "sparseExplorer.revealInExplorer",
          "when": "false"
        },
        {
          "command": "sparseExplorer.expandDir",
          "when": "false"
        },
        {
          "command": "sparseExplorer.collapseDir",
          "when": "false"
        },
        {
          "command": "sparseExplorer.filterDir",
          "when": "false"
        },
        {
          "command": "sparseExplorer.clearFilterDir",
          "when": "false"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "sparseExplorer.view",
        "contents": "No open tabs or pinned files.\n\nOpen a file to see it here, or right-click a file in the Explorer and pin it."
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "@vscode/vsce-sign@2.0.9": true,
    "keytar@7.9.0": true
  }
}
