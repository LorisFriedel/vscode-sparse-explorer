{
  "name": "vscode-sparse-explorer",
  "displayName": "VSCode Sparse Explorer",
  "description": "A sparse explorer showing only open tabs and pinned files, with expand-all and recursive filter per directory",
  "version": "0.0.5",
  "publisher": "eric-mountain",
  "repository": {
    "type": "git",
    "url": "https://github.com/EricMountain/vscode-sparse-explorer"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "icon": "resources/sparse-explorer-icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sparseExplorer",
          "title": "Sparse Explorer",
          "icon": "resources/sparse-explorer.svg"
        }
      ]
    },
    "views": {
      "sparseExplorer": [
        {
          "id": "sparseExplorer.view",
          "name": "Sparse Explorer"
        }
      ]
    },
    "commands": [
      {
        "command": "sparseExplorer.ejectItem",
        "title": "Remove from View",
        "icon": "$(close)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.expandAll",
        "title": "Show All Files",
        "icon": "$(expand-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.collapseToFiltered",
        "title": "Collapse to Filtered View",
        "icon": "$(collapse-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.filterExpanded",
        "title": "Filter Files...",
        "icon": "$(search)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.clearFilter",
        "title": "Clear Filter",
        "icon": "$(clear-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.revealInExplorer",
        "title": "Reveal in Explorer",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.expandDir",
        "title": "Show All Files",
        "icon": "$(expand-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.collapseDir",
        "title": "Collapse to Filtered View",
        "icon": "$(collapse-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.filterDir",
        "title": "Filter Files...",
        "icon": "$(search)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.clearFilterDir",
        "title": "Clear Filter",
        "icon": "$(clear-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.newFile",
        "title": "New File...",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.newFolder",
        "title": "New Folder...",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.copyPath",
        "title": "Copy Path",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.copyRelativePath",
        "title": "Copy Relative Path",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.rename",
        "title": "Rename...",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.delete",
        "title": "Delete",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.openToSide",
        "title": "Open to the Side",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.openWith",
        "title": "Open With...",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.selectForCompare",
        "title": "Select for Compare",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.compareWithSelected",
        "title": "Compare with Selected",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.cut",
        "title": "Cut",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.copy",
        "title": "Copy",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.paste",
        "title": "Paste",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.revealInOSMac",
        "title": "Reveal in Finder",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.revealInOSWindows",
        "title": "Reveal in File Explorer",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.revealInOSLinux",
        "title": "Open Containing Folder",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.openInIntegratedTerminal",
        "title": "Open in Integrated Terminal",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.findInFolder",
        "title": "Find in Folder...",
        "category": "Sparse Explorer"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sparseExplorer.filterExpanded",
          "when": "view == sparseExplorer.view && sparseExplorer.hasExpanded && !sparseExplorer.rootHasFilter",
          "group": "navigation@1"
        },
        {
          "command": "sparseExplorer.clearFilter",
          "when": "view == sparseExplorer.view && sparseExplorer.rootHasFilter",
          "group": "navigation@1"
        },
        {
          "command": "sparseExplorer.expandAll",
          "when": "view == sparseExplorer.view && !sparseExplorer.hasExpanded",
          "group": "navigation@2"
        },
        {
          "command": "sparseExplorer.collapseToFiltered",
          "when": "view == sparseExplorer.view && sparseExplorer.hasExpanded",
          "group": "navigation@2"
        },
        {
          "command": "sparseExplorer.refresh",
          "when": "view == sparseExplorer.view",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "sparseExplorer.ejectItem",
          "when": "view == sparseExplorer.view && viewItem == 'seFile'",
          "group": "inline@1"
        },
        {
          "command": "sparseExplorer.expandDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.filtered' || viewItem == 'seDir.workspaceRoot')",
          "group": "inline@1"
        },
        {
          "command": "sparseExplorer.filterDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.expanded' || viewItem == 'seDir.workspaceRoot.expanded')",
          "group": "inline@2"
        },
        {
          "command": "sparseExplorer.clearFilterDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.expandedFiltered' || viewItem == 'seDir.workspaceRoot.expandedFiltered')",
          "group": "inline@2"
        },
        {
          "command": "sparseExplorer.collapseDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.expanded' || viewItem == 'seDir.expandedFiltered' || viewItem == 'seDir.workspaceRoot.expanded' || viewItem == 'seDir.workspaceRoot.expandedFiltered')",
          "group": "inline@3"
        },
        {
          "command": "sparseExplorer.ejectItem",
          "when": "view == sparseExplorer.view && viewItem == 'seFile'",
          "group": "1_actions@1"
        },
        {
          "command": "sparseExplorer.expandDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.filtered' || viewItem == 'seDir.workspaceRoot')",
          "group": "1_actions@1"
        },
        {
          "command": "sparseExplorer.filterDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.expanded' || viewItem == 'seDir.expandedFiltered' || viewItem == 'seDir.workspaceRoot.expanded' || viewItem == 'seDir.workspaceRoot.expandedFiltered')",
          "group": "1_actions@1"
        },
        {
          "command": "sparseExplorer.clearFilterDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.expandedFiltered' || viewItem == 'seDir.workspaceRoot.expandedFiltered')",
          "group": "1_actions@2"
        },
        {
          "command": "sparseExplorer.collapseDir",
          "when": "view == sparseExplorer.view && (viewItem == 'seDir.expanded' || viewItem == 'seDir.expandedFiltered' || viewItem == 'seDir.workspaceRoot.expanded' || viewItem == 'seDir.workspaceRoot.expandedFiltered')",
          "group": "1_actions@3"
        },
        {
          "command": "sparseExplorer.revealInExplorer",
          "when": "view == sparseExplorer.view",
          "group": "2_reveal@1"
        },
        {
          "command": "sparseExplorer.openToSide",
          "when": "view == sparseExplorer.view && viewItem == 'seFile'",
          "group": "0_open@1"
        },
        {
          "command": "sparseExplorer.openWith",
          "when": "view == sparseExplorer.view && viewItem == 'seFile'",
          "group": "0_open@2"
        },
        {
          "command": "sparseExplorer.newFile",
          "when": "view == sparseExplorer.view && viewItem =~ /^seDir/",
          "group": "0_new@1"
        },
        {
          "command": "sparseExplorer.newFolder",
          "when": "view == sparseExplorer.view && viewItem =~ /^seDir/",
          "group": "0_new@2"
        },
        {
          "command": "sparseExplorer.selectForCompare",
          "when": "view == sparseExplorer.view && viewItem == 'seFile'",
          "group": "1_compare@1"
        },
        {
          "command": "sparseExplorer.compareWithSelected",
          "when": "view == sparseExplorer.view && viewItem == 'seFile'",
          "group": "1_compare@2"
        },
        {
          "command": "sparseExplorer.cut",
          "when": "view == sparseExplorer.view",
          "group": "2_clipboard@1"
        },
        {
          "command": "sparseExplorer.copy",
          "when": "view == sparseExplorer.view",
          "group": "2_clipboard@2"
        },
        {
          "command": "sparseExplorer.paste",
          "when": "view == sparseExplorer.view && sparseExplorer.hasClipboard",
          "group": "2_clipboard@3"
        },
        {
          "command": "sparseExplorer.copyPath",
          "when": "view == sparseExplorer.view",
          "group": "3_copy@1"
        },
        {
          "command": "sparseExplorer.copyRelativePath",
          "when": "view == sparseExplorer.view",
          "group": "3_copy@2"
        },
        {
          "command": "sparseExplorer.rename",
          "when": "view == sparseExplorer.view",
          "group": "4_modify@1"
        },
        {
          "command": "sparseExplorer.delete",
          "when": "view == sparseExplorer.view",
          "group": "4_modify@2"
        },
        {
          "command": "sparseExplorer.revealInOSMac",
          "when": "view == sparseExplorer.view && isMac",
          "group": "5_os@1"
        },
        {
          "command": "sparseExplorer.revealInOSWindows",
          "when": "view == sparseExplorer.view && isWindows",
          "group": "5_os@1"
        },
        {
          "command": "sparseExplorer.revealInOSLinux",
          "when": "view == sparseExplorer.view && isLinux",
          "group": "5_os@1"
        },
        {
          "command": "sparseExplorer.openInIntegratedTerminal",
          "when": "view == sparseExplorer.view && viewItem =~ /^seDir/",
          "group": "5_os@2"
        },
        {
          "command": "sparseExplorer.findInFolder",
          "when": "view == sparseExplorer.view && viewItem =~ /^seDir/",
          "group": "5_os@3"
        }
      ],
      "commandPalette": [
        {
          "command": "sparseExplorer.ejectItem",
          "when": "false"
        },
        {
          "command": "sparseExplorer.expandAll",
          "when": "false"
        },
        {
          "command": "sparseExplorer.collapseToFiltered",
          "when": "false"
        },
        {
          "command": "sparseExplorer.filterExpanded",
          "when": "false"
        },
        {
          "command": "sparseExplorer.clearFilter",
          "when": "false"
        },
        {
          "command": "sparseExplorer.revealInExplorer",
          "when": "false"
        },
        {
          "command": "sparseExplorer.expandDir",
          "when": "false"
        },
        {
          "command": "sparseExplorer.collapseDir",
          "when": "false"
        },
        {
          "command": "sparseExplorer.filterDir",
          "when": "false"
        },
        {
          "command": "sparseExplorer.clearFilterDir",
          "when": "false"
        },
        {
          "command": "sparseExplorer.newFile",
          "when": "false"
        },
        {
          "command": "sparseExplorer.newFolder",
          "when": "false"
        },
        {
          "command": "sparseExplorer.copyPath",
          "when": "false"
        },
        {
          "command": "sparseExplorer.copyRelativePath",
          "when": "false"
        },
        {
          "command": "sparseExplorer.rename",
          "when": "false"
        },
        {
          "command": "sparseExplorer.delete",
          "when": "false"
        },
        {
          "command": "sparseExplorer.openToSide",
          "when": "false"
        },
        {
          "command": "sparseExplorer.openWith",
          "when": "false"
        },
        {
          "command": "sparseExplorer.selectForCompare",
          "when": "false"
        },
        {
          "command": "sparseExplorer.compareWithSelected",
          "when": "false"
        },
        {
          "command": "sparseExplorer.cut",
          "when": "false"
        },
        {
          "command": "sparseExplorer.copy",
          "when": "false"
        },
        {
          "command": "sparseExplorer.paste",
          "when": "false"
        },
        {
          "command": "sparseExplorer.revealInOSMac",
          "when": "false"
        },
        {
          "command": "sparseExplorer.revealInOSWindows",
          "when": "false"
        },
        {
          "command": "sparseExplorer.revealInOSLinux",
          "when": "false"
        },
        {
          "command": "sparseExplorer.openInIntegratedTerminal",
          "when": "false"
        },
        {
          "command": "sparseExplorer.findInFolder",
          "when": "false"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "sparseExplorer.view",
        "contents": "No open tabs or pinned files.\n\nOpen a file to see it here, or right-click a file in the Explorer and pin it."
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package",
    "test": "jest",
    "release": "scripts/release.sh"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "@vscode/vsce-sign@2.0.9": true,
    "keytar@7.9.0": true
  }
}
