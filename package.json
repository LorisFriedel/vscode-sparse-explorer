{
  "name": "vscode-sparse-explorer",
  "displayName": "VSCode Sparse Explorer",
  "description": "A sparse explorer showing only open tabs and pinned files, with expand-all and recursive filter per directory",
  "version": "0.0.1",
  "publisher": "eric-mountain",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "explorerFilter",
          "title": "Filtered Explorer",
          "icon": "resources/filter.svg"
        }
      ]
    },
    "views": {
      "explorerFilter": [
        {
          "id": "explorerFilter.view",
          "name": "Filtered Explorer"
        }
      ]
    },
    "commands": [
      {
        "command": "explorerFilter.pinItem",
        "title": "Pin",
        "icon": "$(pin)",
        "category": "Explorer Filter"
      },
      {
        "command": "explorerFilter.unpinItem",
        "title": "Unpin",
        "icon": "$(pinned)",
        "category": "Explorer Filter"
      },
      {
        "command": "explorerFilter.expandAll",
        "title": "Show All Files",
        "icon": "$(expand-all)",
        "category": "Explorer Filter"
      },
      {
        "command": "explorerFilter.collapseToFiltered",
        "title": "Collapse to Filtered View",
        "icon": "$(collapse-all)",
        "category": "Explorer Filter"
      },
      {
        "command": "explorerFilter.filterExpanded",
        "title": "Filter Files...",
        "icon": "$(search)",
        "category": "Explorer Filter"
      },
      {
        "command": "explorerFilter.clearFilter",
        "title": "Clear Filter",
        "icon": "$(clear-all)",
        "category": "Explorer Filter"
      },
      {
        "command": "explorerFilter.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Explorer Filter"
      },
      {
        "command": "explorerFilter.revealInExplorer",
        "title": "Reveal in Explorer",
        "category": "Explorer Filter"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "explorerFilter.refresh",
          "when": "view == explorerFilter.view",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "explorerFilter.pinItem",
          "when": "view == explorerFilter.view && viewItem == efFile.unpinned",
          "group": "inline@1"
        },
        {
          "command": "explorerFilter.unpinItem",
          "when": "view == explorerFilter.view && viewItem == efFile.pinned",
          "group": "inline@1"
        },
        {
          "command": "explorerFilter.expandAll",
          "when": "view == explorerFilter.view && viewItem == efDir.filtered",
          "group": "inline@1"
        },
        {
          "command": "explorerFilter.filterExpanded",
          "when": "view == explorerFilter.view && viewItem == efDir.expanded",
          "group": "inline@2"
        },
        {
          "command": "explorerFilter.clearFilter",
          "when": "view == explorerFilter.view && viewItem == efDir.expandedFiltered",
          "group": "inline@2"
        },
        {
          "command": "explorerFilter.collapseToFiltered",
          "when": "view == explorerFilter.view && (viewItem == efDir.expanded || viewItem == efDir.expandedFiltered)",
          "group": "inline@3"
        },
        {
          "command": "explorerFilter.pinItem",
          "when": "view == explorerFilter.view && viewItem == efFile.unpinned",
          "group": "1_actions@1"
        },
        {
          "command": "explorerFilter.unpinItem",
          "when": "view == explorerFilter.view && viewItem == efFile.pinned",
          "group": "1_actions@1"
        },
        {
          "command": "explorerFilter.expandAll",
          "when": "view == explorerFilter.view && viewItem == efDir.filtered",
          "group": "1_actions@1"
        },
        {
          "command": "explorerFilter.filterExpanded",
          "when": "view == explorerFilter.view && (viewItem == efDir.expanded || viewItem == efDir.expandedFiltered)",
          "group": "1_actions@1"
        },
        {
          "command": "explorerFilter.clearFilter",
          "when": "view == explorerFilter.view && viewItem == efDir.expandedFiltered",
          "group": "1_actions@2"
        },
        {
          "command": "explorerFilter.collapseToFiltered",
          "when": "view == explorerFilter.view && (viewItem == efDir.expanded || viewItem == efDir.expandedFiltered)",
          "group": "1_actions@3"
        },
        {
          "command": "explorerFilter.revealInExplorer",
          "when": "view == explorerFilter.view",
          "group": "2_reveal@1"
        }
      ],
      "commandPalette": [
        {
          "command": "explorerFilter.pinItem",
          "when": "false"
        },
        {
          "command": "explorerFilter.unpinItem",
          "when": "false"
        },
        {
          "command": "explorerFilter.expandAll",
          "when": "false"
        },
        {
          "command": "explorerFilter.collapseToFiltered",
          "when": "false"
        },
        {
          "command": "explorerFilter.filterExpanded",
          "when": "false"
        },
        {
          "command": "explorerFilter.clearFilter",
          "when": "false"
        },
        {
          "command": "explorerFilter.revealInExplorer",
          "when": "false"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "explorerFilter.view",
        "contents": "No open tabs or pinned files.\n\nOpen a file to see it here, or right-click a file in the Explorer and pin it."
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
