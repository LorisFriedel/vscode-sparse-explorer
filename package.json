{
  "name": "vscode-sparse-explorer",
  "displayName": "VSCode Sparse Explorer",
  "description": "A sparse explorer showing only open tabs and pinned files, with expand-all and recursive filter per directory",
  "version": "0.0.1",
  "publisher": "eric-mountain",
  "repository": {
    "type": "git",
    "url": "https://github.com/EricMountain/vscode-sparse-explorer"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sparseExplorer",
          "title": "Sparse Explorer",
          "icon": "resources/filter.svg"
        }
      ]
    },
    "views": {
      "sparseExplorer": [
        {
          "id": "sparseExplorer.view",
          "name": "Sparse Explorer"
        }
      ]
    },
    "commands": [
      {
        "command": "sparseExplorer.pinItem",
        "title": "Pin",
        "icon": "$(pin)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.unpinItem",
        "title": "Unpin",
        "icon": "$(pinned)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.expandAll",
        "title": "Show All Files",
        "icon": "$(expand-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.collapseToFiltered",
        "title": "Collapse to Filtered View",
        "icon": "$(collapse-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.filterExpanded",
        "title": "Filter Files...",
        "icon": "$(search)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.clearFilter",
        "title": "Clear Filter",
        "icon": "$(clear-all)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Sparse Explorer"
      },
      {
        "command": "sparseExplorer.revealInExplorer",
        "title": "Reveal in Explorer",
        "category": "Sparse Explorer"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sparseExplorer.refresh",
          "when": "view == sparseExplorer.view",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "sparseExplorer.pinItem",
          "when": "view == sparseExplorer.view && viewItem == seFile.unpinned",
          "group": "inline@1"
        },
        {
          "command": "sparseExplorer.unpinItem",
          "when": "view == sparseExplorer.view && viewItem == seFile.pinned",
          "group": "inline@1"
        },
        {
          "command": "sparseExplorer.expandAll",
          "when": "view == sparseExplorer.view && viewItem == seDir.filtered",
          "group": "inline@1"
        },
        {
          "command": "sparseExplorer.filterExpanded",
          "when": "view == sparseExplorer.view && viewItem == seDir.expanded",
          "group": "inline@2"
        },
        {
          "command": "sparseExplorer.clearFilter",
          "when": "view == sparseExplorer.view && viewItem == seDir.expandedFiltered",
          "group": "inline@2"
        },
        {
          "command": "sparseExplorer.collapseToFiltered",
          "when": "view == sparseExplorer.view && (viewItem == seDir.expanded || viewItem == seDir.expandedFiltered)",
          "group": "inline@3"
        },
        {
          "command": "sparseExplorer.pinItem",
          "when": "view == sparseExplorer.view && viewItem == seFile.unpinned",
          "group": "1_actions@1"
        },
        {
          "command": "sparseExplorer.unpinItem",
          "when": "view == sparseExplorer.view && viewItem == seFile.pinned",
          "group": "1_actions@1"
        },
        {
          "command": "sparseExplorer.expandAll",
          "when": "view == sparseExplorer.view && viewItem == seDir.filtered",
          "group": "1_actions@1"
        },
        {
          "command": "sparseExplorer.filterExpanded",
          "when": "view == sparseExplorer.view && (viewItem == seDir.expanded || viewItem == seDir.expandedFiltered)",
          "group": "1_actions@1"
        },
        {
          "command": "sparseExplorer.clearFilter",
          "when": "view == sparseExplorer.view && viewItem == seDir.expandedFiltered",
          "group": "1_actions@2"
        },
        {
          "command": "sparseExplorer.collapseToFiltered",
          "when": "view == sparseExplorer.view && (viewItem == seDir.expanded || viewItem == seDir.expandedFiltered)",
          "group": "1_actions@3"
        },
        {
          "command": "sparseExplorer.revealInExplorer",
          "when": "view == sparseExplorer.view",
          "group": "2_reveal@1"
        }
      ],
      "commandPalette": [
        {
          "command": "sparseExplorer.pinItem",
          "when": "false"
        },
        {
          "command": "sparseExplorer.unpinItem",
          "when": "false"
        },
        {
          "command": "sparseExplorer.expandAll",
          "when": "false"
        },
        {
          "command": "sparseExplorer.collapseToFiltered",
          "when": "false"
        },
        {
          "command": "sparseExplorer.filterExpanded",
          "when": "false"
        },
        {
          "command": "sparseExplorer.clearFilter",
          "when": "false"
        },
        {
          "command": "sparseExplorer.revealInExplorer",
          "when": "false"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "sparseExplorer.view",
        "contents": "No open tabs or pinned files.\n\nOpen a file to see it here, or right-click a file in the Explorer and pin it."
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
